void calculatePID(float current_velocity, float dt, int interval, unsigned long currentMillis) {
    SETPOINT = setpoint;
//  int x = 48;
//  accel = x * SETPOINT / 60000.0; //accelerator variable, change the x for adjustment
//  vref = vold + (accel * interval);
//  if (vref > SETPOINT){
    vref = SETPOINT;
//  }
  
  pid_error = vref - current_velocity;
  Serial.print(" | PIDsp error: ");
  Serial.println(pid_error);
  pid_proportional = KP * pid_error;
  pid_integral += pid_error * dt;
  if (pid_integral > 600) pid_integral = 600.00;
  if (pid_integral < -600) pid_integral = -600.00;
  pid_integral_term = KI * pid_integral;
  pid_derivative = KD * (pid_error - pid_prev_error) / dt;
  pid_output = pid_proportional + pid_integral_term + pid_derivative;

  int pid_command = NEUTRAL_PWM + (int)pid_output;
  pwm_command = pid_command;
  
  pwm_command = constrain(pwm_command, 1000, 2000);
  Serial.print(" PID pwm: ");
  Serial.println(pwm_command);

//  setTraction(1545);
  setTraction(pwm_command);
  pid_prev_error = pid_error;
  vold = vref;
}

void calculatePIDsteer(float current_yaw, float dts, int intervals, unsigned long currentMillis) {

  float angleBuff = bufferAngle (angle);
//  float angleBuff = 0;
  pids_error = angleBuff - current_yaw;
////  Serial.print("Angle SP: ");
////  Serial.println(angle);
  Serial.print("Angle Buff: ");
  Serial.print(angleBuff);
  Serial.print(" | Yaw: ");
  Serial.print(current_yaw);
  Serial.print(" | PIDst error: ");
  Serial.println(pids_error);
  pids_proportional = KPS * pids_error;
  pids_integral += pids_error * dts;
  if (pids_integral > 600) pids_integral = 600.00;
  if (pids_integral < -600) pids_integral = -600.00;
  pids_integral_term = KIS * pids_integral;
  pids_derivative = KDS * (pids_error - pids_prev_error) / dts;
  pids_output = pids_proportional + pids_integral_term + pids_derivative;

  if (angleBuff < 0.0){
     NEUTRAL_PWMS = 1567;
  } else if (angleBuff > 0.0){
     NEUTRAL_PWMS = 1456;
  } else if (aold > 0.0 && angleBuff < 0.0) {
     NEUTRAL_PWMS = 1529;
  } else {
    NEUTRAL_PWMS = 1480;
  }
  int pids_command = NEUTRAL_PWMS - (int)pids_output;
  pwm_steer_command = pids_command;
  
  pwm_steer_command = constrain(pwm_steer_command, 900, 1900);
  Serial.print(" PID pwm steer: ");
  Serial.println(pwm_steer_command);

//  setSteer(1540);
  setSteer(pwm_steer_command);
  pids_prev_error = pids_error;
  aold = angle;
}
